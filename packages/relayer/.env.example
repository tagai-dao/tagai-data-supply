# MySQL（复用 tiptag 库，独立 DB 用户）spec §5.6
TDS_DB_HOST=127.0.0.1
TDS_DB_PORT=3306
TDS_DB_USER=tds_writer
TDS_DB_PASSWORD=changeme
TDS_DB_DATABASE=tiptag

# 服务
TDS_WS_PORT=7700
TDS_HTTP_PORT=7701
TDS_ADMIN_TOKEN=changeme-admin-token

# 协议
TDS_PROTOCOL_VERSION=1

# Node CLI 版本与 GitHub Release（/node/version 自动读 GitHub 最新 node-v* release）
TDS_NODE_MIN_MAJOR=0
TDS_NODE_GITHUB_REPO=tagai-dao/tagai-data-supply
TDS_NODE_RELEASE_TAG_PREFIX=node-v
# 可选：GitHub API token（提高 rate limit）；release 缓存 TTL 毫秒，默认 900000
# TDS_NODE_GITHUB_TOKEN=
# TDS_NODE_RELEASE_CACHE_TTL_MS=900000

# tagai-api 地址（验证 node 绑定账号）
TAGAI_API_BASE=http://127.0.0.1:3001

# 日志（终端输出级别；管理页缓冲始终收录 trace+，可在页面按级别筛选）
LOG_LEVEL=info
# pretty=彩色可读（yarn dev 默认）| json=结构化单行（生产/PM2 推荐）
LOG_FORMAT=pretty
