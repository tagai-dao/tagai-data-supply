{
  "name": "@tds/relayer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node src/server/app.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/admin/public','dist/admin/public',{recursive:true})\"",
    "build:web": "cd web && yarn install && yarn build",
    "build:all": "yarn build:web && yarn build",
    "start": "node dist/server/app.js",
    "test": "jest",
    "verify-schema": "ts-node src/db/verify-schema.ts"
  },
  "dependencies": {
    "@tds/shared": "0.0.1",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "mysql2": "^3.11.0",
    "nanoid": "^3.3.7",
    "pino": "^9.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
