{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task_assign.json",
  "title": "TaskAssign",
  "type": "object",
  "required": ["type", "assignment_id", "subtask_id", "task_type", "params", "mode"],
  "properties": {
    "type": { "const": "task_assign" },
    "assignment_id": { "type": "string" },
    "subtask_id": { "type": "string" },
    "task_type": { "type": "string", "enum": ["hashtag", "user_timeline", "keyword", "list"] },
    "params": { "type": "object" },
    "mode": { "type": "string", "enum": ["continuous", "round"] },
    "watermark_tweet_id": { "type": "string" },
    "round_window": { "type": "object" }
  },
  "additionalProperties": false
}
