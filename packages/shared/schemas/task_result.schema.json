{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task_result.json",
  "title": "TaskResult",
  "type": "object",
  "required": ["type", "assignment_id", "subtask_id", "status"],
  "properties": {
    "type": { "const": "task_result" },
    "assignment_id": { "type": "string" },
    "subtask_id": { "type": "string" },
    "status": { "type": "string", "enum": ["done", "failed"] },
    "tweets": { "type": "array", "items": { "type": "object" } },
    "error": { "type": "string" },
    "cookie_status": { "type": "string", "enum": ["ok", "rate_limited", "auth_failed", "error", "unknown"] }
  },
  "additionalProperties": false
}
